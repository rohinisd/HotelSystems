# =============================================================================
# SFMS Environment Variables
# Copy this file to .env in the project root and fill in the values
# =============================================================================

# Database
POSTGRES_DB=sfms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:changeme_strong_password@localhost:5432/sfms
JWT_SECRET=                         # REQUIRED: generate with `openssl rand -hex 32`
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
RAZORPAY_KEY_ID=rzp_test_xxx       # Get from Razorpay Dashboard
RAZORPAY_KEY_SECRET=                # Get from Razorpay Dashboard
CORS_ORIGINS=["http://localhost:3000"]
SMS_API_KEY=                        # Optional: MSG91 or Twilio
APP_ENV=dev
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
