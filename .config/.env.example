# =============================================================================
# Hotel Management System - Environment Variables
# Copy to .env in project root or docker/ and fill in values.
# =============================================================================

# Database (for Docker Compose or local Postgres)
POSTGRES_DB=hotel_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:changeme_strong_password@localhost:5432/hotel_db
JWT_SECRET=                         # REQUIRED in production: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# On server, add your frontend origin, e.g. ["http://localhost:3000","http://72.60.101.226:3000"]
# Google OAuth: use Client ID only. Never commit the Client Secret.
GOOGLE_CLIENT_ID=404972369080-jsamrbi717ghjlvkjh1dgd2ialueaima.apps.googleusercontent.com
APP_ENV=dev
DEBUG=true

# Frontend (set when running frontend). On server use public URL so browser can reach API:
# NEXT_PUBLIC_API_URL=http://72.60.101.226:8001
NEXT_PUBLIC_API_URL=http://localhost:8001
# For Google Sign-In button (same value as GOOGLE_CLIENT_ID):
NEXT_PUBLIC_GOOGLE_CLIENT_ID=404972369080-jsamrbi717ghjlvkjh1dgd2ialueaima.apps.googleusercontent.com
